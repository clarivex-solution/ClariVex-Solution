"use client";

import ContactForm from "@/components/ContactForm";
import { useCountry } from "@/components/CountryProvider";
import Hero, { HeroSkeleton } from "@/components/Hero";
import { AccountingServiceSchema } from "@/components/JsonLd";
import { getContent } from "@/lib/countryContent";
import { countries } from "@/lib/countryData";
import {
    phoneContacts,
    processSteps,
    serviceCards,
    whyChooseUsCards
} from "@/lib/siteData";
import {
    CheckCircle,
    Mail,
    MapPin,
    Phone,
} from "lucide-react";
import Image from "next/image";
import Link from "next/link";

export default function HomeContent() {
  const { country, ready } = useCountry();
  const content = getContent(country);

  return (
    <main>
      <AccountingServiceSchema countryCode={country} content={content} />
      <section id="home">
        {!ready ? (
          <HeroSkeleton />
        ) : (
          <Hero
            countryLabel={content.hero.countryLabel}
            h1Line1={content.hero.h1Line1}
            h1Line2={content.hero.h1Line2}
            subtitle={content.hero.subtitle}
            flagSrc={content.hero.flagSrc}
            seoH1={content.seo.h1}
          />
        )}
      </section>

      {/* Trusted Software bar */}
      <section className="bg-[/* TO REPLACE */ border-y border-[/* TO REPLACE */ py-5">
        <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
          <div className="flex flex-wrap items-center justify-center gap-2">
            <span className="hidden shrink-0 mr-4 text-xs uppercase tracking-widest text-[/* TO REPLACE */ sm:inline">
              Trusted Software:
            </span>
            {content.trustedSoftware.map((tool) => (
              <span
                key={tool}
                className="bg-white border border-[/* TO REPLACE */ text-[/* TO REPLACE */ text-xs rounded-full px-4 py-1.5 whitespace-nowrap hover:border-[/* TO REPLACE *//50 hover:text-[/* TO REPLACE */ transition-colors"
              >
                {tool}
              </span>
            ))}
          </div>
        </div>
      </section>

      {/* Compliance banner (country-specific only) */}
      {content.compliance && (
        <section className="bg-white py-8 sm:py-10 lg:py-12">
          <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
            <div className="rounded-2xl border border-[/* TO REPLACE *//20 bg-[/* TO REPLACE */ p-8">
              <div className="grid gap-8 lg:grid-cols-[1.1fr_1fr] lg:items-center">
                <div>
                  <div className="flex items-center gap-3">
                    <div className="h-px w-16 bg-[/* TO REPLACE */" />
                    <p className="text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">
                      {content.hero.flagSrc && (
                        <img src={content.hero.flagSrc} alt="" className="inline-block mr-2 rounded-sm" style={{ width: 18, height: 12 }} />
                      )}
                      Tax &amp; Compliance Coverage
                    </p>
                  </div>
                  <h3 className="mt-4 font-[family-name:var(--font-playfair)] text-2xl text-[/* TO REPLACE */">
                    Regional Compliance
                  </h3>
                </div>
                <div>
                  <p className="text-sm leading-relaxed text-[/* TO REPLACE */">{content.compliance.note}</p>
                  <div className="mt-4 flex flex-wrap gap-2">
                    {content.compliance.tools.map((tool) => (
                      <span key={tool} className="rounded-full border border-[/* TO REPLACE */ bg-white px-3 py-1.5 text-xs text-[/* TO REPLACE */">
                        {tool}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      )}

      {/* Process */}
      <section id="process" className="bg-white py-16 sm:py-20 lg:py-32">
        <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
          <div className="mb-6 h-px w-16 bg-[/* TO REPLACE */" />
          <p className="text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">HOW WE WORK</p>
          <h2 className="mt-4 max-w-2xl font-[family-name:var(--font-playfair)] text-3xl font-bold text-[/* TO REPLACE */ sm:text-4xl lg:text-5xl">
            A disciplined process for measurable financial control
          </h2>
          <div className="mt-12 grid gap-6 md:grid-cols-2 lg:mt-20 lg:grid-cols-4">
            {processSteps.map((step) => (
              <article key={step.step} className="group rounded-xl border border-[/* TO REPLACE */ bg-[/* TO REPLACE */ p-8 transition-all duration-300 hover:border-[/* TO REPLACE *//50 hover:shadow-lg">
                <p className="font-[family-name:var(--font-playfair)] text-5xl font-bold text-[/* TO REPLACE */ transition-colors group-hover:text-[/* TO REPLACE *//20">{step.step}</p>
                <step.icon className="mt-4 h-6 w-6 text-[/* TO REPLACE */" />
                <h3 className="mt-3 text-lg font-semibold text-[/* TO REPLACE */">{step.title}</h3>
                <p className="mt-3 text-sm leading-relaxed text-[/* TO REPLACE */">{step.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      {/* Services */}
      <section id="services" className="bg-[/* TO REPLACE */ py-16 sm:py-20 lg:py-32">
        <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
          <div className="mb-6 h-px w-16 bg-[/* TO REPLACE */" />
          <p className="text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">OUR SERVICES</p>
          <h2 className="mt-4 font-[family-name:var(--font-playfair)] text-3xl font-bold text-[/* TO REPLACE */ sm:text-4xl lg:text-5xl">
            Comprehensive Financial Solutions
          </h2>
          <div className="mt-12 grid gap-6 md:grid-cols-2 lg:mt-20 lg:grid-cols-3">
            {serviceCards.map((service) => (
              <article key={service.title} className="group cursor-pointer rounded-xl border border-slate-200 bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:border-[/* TO REPLACE *//40 hover:shadow-xl">
                <div className="flex h-12 w-12 items-center justify-center rounded-xl bg-[/* TO REPLACE *//10 text-[/* TO REPLACE */ transition-colors duration-300 group-hover:bg-[/* TO REPLACE */ group-hover:text-white">
                  <service.icon className="h-5 w-5" />
                </div>
                <h3 className="mt-6 text-lg font-semibold text-[/* TO REPLACE */">{service.title}</h3>
                <p className="mt-2 text-sm leading-relaxed text-slate-500">{service.description}</p>
                <Link href={service.href} className="mt-6 inline-block text-sm font-medium text-[/* TO REPLACE */ transition-colors hover:text-[/* TO REPLACE */">
                  Learn More &rarr;
                </Link>
              </article>
            ))}
          </div>
        </div>
      </section>

      {/* Stats */}
      <section className="border-y border-[/* TO REPLACE */ bg-[/* TO REPLACE */ py-16 sm:py-20 lg:py-32">
        <div className="mx-auto grid max-w-7xl grid-cols-2 gap-8 px-4 text-center sm:px-6 lg:grid-cols-4 lg:gap-12 lg:px-12">
          {content.stats.map((stat) => (
            <div key={stat.label}>
              <p className="font-[family-name:var(--font-playfair)] text-4xl font-bold text-[/* TO REPLACE */ lg:text-6xl">{stat.value}</p>
              <div className="mx-auto mt-3 h-0.5 w-8 bg-[/* TO REPLACE */" />
              <p className="mt-4 text-sm uppercase tracking-wider text-[/* TO REPLACE */">{stat.label}</p>
            </div>
          ))}
        </div>
      </section>

      {/* Software */}
      <section className="bg-white py-16 sm:py-20 lg:py-32">
        <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
          <div className="mb-6 h-px w-16 bg-[/* TO REPLACE */" />
          <p className="text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">TOOLS &amp; TECHNOLOGY</p>
          <h2 className="mt-4 font-[family-name:var(--font-playfair)] text-3xl font-bold text-[/* TO REPLACE */ sm:text-4xl lg:text-5xl">
            Software We Work With
          </h2>
          <p className="mt-4 max-w-2xl text-[/* TO REPLACE */">
            Built on the tools modern finance teams rely on. We adapt to your systems &mdash; no forced migrations, no disruption.
          </p>
          <div className="mt-12 grid gap-8 lg:mt-20 lg:grid-cols-3">
            {content.softwareColumns.map((column) => (
              <article key={column.title} className="rounded-xl border border-[/* TO REPLACE */ bg-[/* TO REPLACE */ p-8">
                <h3 className="mb-6 border-b border-[/* TO REPLACE */ pb-4 font-semibold text-[/* TO REPLACE */">{column.title}</h3>
                <div className="mt-2">
                  {column.tools.map((tool) => (
                    <div key={tool} className="flex items-center gap-3 border-b border-[/* TO REPLACE *//50 py-3 text-sm text-[/* TO REPLACE */ transition-colors hover:text-[/* TO REPLACE */">
                      <span className="h-1.5 w-1.5 shrink-0 rounded-full bg-[/* TO REPLACE */" />
                      <span>{tool}</span>
                    </div>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      {/* About */}
      <section id="about" className="bg-[/* TO REPLACE */ py-16 sm:py-20 lg:py-32">
        <div className="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-20 lg:px-12">
          <div className="relative rounded-2xl border border-[/* TO REPLACE */ bg-white p-10 shadow-lg">
            <div className="absolute left-0 top-0 h-20 w-20 rounded-tl-2xl border-l-2 border-t-2 border-[/* TO REPLACE *//40" />
            <div className="relative w-24 h-24 rounded-full overflow-hidden ring-2 ring-[/* TO REPLACE *//40 shrink-0">
              <Image src="/dhimant-khatri.png" alt="CA Dhimant Khatri" fill sizes="96px" className="w-full h-full object-cover object-top" />
            </div>
            <p className="mt-6 font-[family-name:var(--font-playfair)] text-2xl font-bold text-[/* TO REPLACE */">Dhimant Khatri</p>
            <p className="mt-1 text-sm text-[/* TO REPLACE */">Chartered Accountant &middot; ICAI Member</p>
            <div className="mt-6 h-px w-12 bg-[/* TO REPLACE */" />
            <div className="mt-6 space-y-4">
              {["15+ Years Professional Experience", "Member, Institute of Chartered Accountants of India", "Audit, Taxation & Compliance Specialist"].map((point) => (
                <p key={point} className="flex items-center gap-3 text-sm text-[/* TO REPLACE */">
                  <CheckCircle className="h-4 w-4 text-[/* TO REPLACE */" />
                  {point}
                </p>
              ))}
            </div>
          </div>
          <div>
            <div className="mb-6 h-px w-16 bg-[/* TO REPLACE */" />
            <p className="text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">ABOUT US</p>
            <h2 className="mt-4 font-[family-name:var(--font-playfair)] text-3xl font-bold text-[/* TO REPLACE */ sm:text-4xl lg:text-5xl">
              Professional Expertise You Can Trust
            </h2>
            <p className="mt-6 leading-relaxed text-slate-600">
              ClariVex Solutions combines deep accounting discipline with modern process control to help leadership teams make faster and safer financial decisions.
            </p>
            <p className="mt-4 leading-relaxed text-slate-600">
              From monthly close readiness to growth-stage advisory, our objective is to reduce friction in finance operations while improving transparency for founders, management, and stakeholders.
            </p>
          </div>
        </div>
      </section>

      {/* Why Choose Us */}
      <section className="bg-white py-16 sm:py-20 lg:py-32">
        <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
          <div className="mb-6 h-px w-16 bg-[/* TO REPLACE */" />
          <p className="text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">WHY CLARIVEX</p>
          <h2 className="mt-4 font-[family-name:var(--font-playfair)] text-3xl font-bold text-[/* TO REPLACE */ sm:text-4xl lg:text-5xl">
            Why Choose ClariVex Solution
          </h2>
          <div className="mt-12 grid gap-6 lg:mt-20 lg:grid-cols-2">
            {whyChooseUsCards.map((item) => (
              <article key={item.title} className="group rounded-xl border border-[/* TO REPLACE */ bg-[/* TO REPLACE */ p-8 transition-all hover:border-[/* TO REPLACE *//40 hover:shadow-lg border-l-4 border-l-[/* TO REPLACE */">
                <div className="flex h-12 w-12 items-center justify-center rounded-xl bg-[/* TO REPLACE *//10 text-[/* TO REPLACE */ transition-colors group-hover:bg-[/* TO REPLACE *//20">
                  <item.icon className="h-5 w-5" />
                </div>
                <h3 className="mt-6 text-lg font-semibold text-[/* TO REPLACE */">{item.title}</h3>
                <div className="mt-4 space-y-2">
                  {item.points.map((point) => (
                    <p key={point} className="flex items-start gap-2 text-sm leading-relaxed text-[/* TO REPLACE */">
                      <span className="mt-2 h-1 w-1 shrink-0 rounded-full bg-[/* TO REPLACE */" />
                      <span>{point}</span>
                    </p>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      {/* Contact */}
      <section id="contact" className="bg-[/* TO REPLACE */ py-16 sm:py-20 lg:py-32">
        <div className="w-full">
          <div className="mx-auto max-w-7xl px-4 sm:px-6 lg:px-12">
            <div className="mx-auto mb-6 h-px w-16 bg-[/* TO REPLACE */" />
            <p className="text-center text-xs uppercase tracking-[0.2em] text-[/* TO REPLACE */">GET IN TOUCH</p>
            <h2 className="mt-4 text-center font-[family-name:var(--font-playfair)] text-3xl font-bold text-[/* TO REPLACE */ sm:text-4xl lg:text-5xl">Contact Us</h2>
            <p className="mt-3 text-center text-slate-500">Book a free consultation today</p>
          </div>
          <div className="mx-auto mt-16 grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:px-12">
            <div className="rounded-2xl border border-[/* TO REPLACE */ bg-white p-10 shadow-lg">
              <h3 className="text-xl font-semibold text-[/* TO REPLACE */">Contact Information</h3>
              <div className="mb-8 mt-3 h-px w-10 bg-[/* TO REPLACE */" />
              <div className="space-y-6">
                <div className="flex items-start gap-3">
                  <MapPin className="h-5 w-5 shrink-0 text-[/* TO REPLACE */" />
                  <p className="text-sm leading-relaxed text-[/* TO REPLACE */">
                    421, Shivalik Shilp, Iscon Cross Road,<br />S.G. Highway, Ahmedabad &ndash; 380058
                  </p>
                </div>
                <div className="flex items-start gap-3">
                  <Mail className="h-5 w-5 shrink-0 text-[/* TO REPLACE */" />
                  <a href={`mailto:${content.contactEmail}`} className="text-sm text-[/* TO REPLACE */ transition-colors hover:text-[/* TO REPLACE */">
                    {content.contactEmail}
                  </a>
                </div>
              </div>
              <div className="my-6 h-px w-full bg-[/* TO REPLACE */" />
              <p className="mb-4 text-sm font-medium text-[/* TO REPLACE */">Our Team</p>
              <div className="space-y-4">
                {phoneContacts.map((contact) => (
                  <div key={contact.phoneRaw} className="flex items-start justify-between gap-3">
                    <div className="flex items-start gap-2">
                      <Phone className="mt-0.5 h-4 w-4 shrink-0 text-[/* TO REPLACE */" />
                      <div>
                        <p className="text-sm font-medium text-[/* TO REPLACE */">{contact.name}</p>
                        <p className="text-xs text-[/* TO REPLACE */">{contact.role}</p>
                      </div>
                    </div>
                    <a href={`tel:${contact.phoneRaw}`} className="shrink-0 font-mono text-sm text-[/* TO REPLACE */">{contact.phoneDisplay}</a>
                  </div>
                ))}
              </div>
              <div className="my-6 h-px w-full bg-[/* TO REPLACE */" />
              <p className="mb-4 text-sm font-medium text-[/* TO REPLACE */">Global Coverage</p>
              <div className="flex flex-wrap gap-2">
                {countries.map((c) => (
                  <span key={c.code} className="flex items-center gap-1.5 rounded-full border border-[/* TO REPLACE */ bg-[/* TO REPLACE */ px-3 py-1.5 text-xs text-[/* TO REPLACE */">
                    <img src={c.flagSrc} alt={c.name} className="rounded-sm" style={{ width: 16, height: 11 }} />
                    {c.name}
                  </span>
                ))}
              </div>
            </div>
            <ContactForm />
          </div>
        </div>
      </section>
    </main>
  );
}
